# Notion Integration Token (created at https://www.notion.so/my-integrations)
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxx

# Database ID of "Hermes Requests" (32-char UUID from Notion URL)
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Hermes Gateway API (default: localhost)
HERMES_API_URL=http://localhost:8642
HERMES_API_KEY=your-hermes-api-server-key

# Model to use (default: hermes-agent)
HERMES_MODEL=hermes-agent

# Local repo where Hermes will write code and run git commands
LOCAL_REPO_PATH=~/notion-hermes

# Git branch to push to
GIT_BRANCH=main

# Poll interval in seconds (watch mode only)
POLL_INTERVAL_SECONDS=20

# Comma-separated whitelist of repos allowed as targets
# Example: user/notion-hermes,org/project-repo
ALLOWED_REPOS=user/notion-hermes
